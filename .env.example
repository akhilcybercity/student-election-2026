# 🗳️ Election Management System — Environment Variables

# ─── Database Mode ──────────────────────────────────────────────────
# Leave all DB_ variables commented out to use the Zero-Dependency Local JSON database (db.json).
# Uncomment them to connect to a MySQL / TiDB Cloud database instead.

# DB_HOST=gateway01.ap-southeast-1.prod.alicloud.tidbcloud.com
# DB_PORT=4000
# DB_USER=your_tidb_user_here
# DB_PASSWORD=your_tidb_password_here
# DB_NAME=test
# DB_SSL=true     ← Set to "true" for TiDB Cloud (port 4000) or any cloud MySQL with SSL

# ─── Auth Secrets ───────────────────────────────────────────────────
# Secret key used for signing JWT tokens. MUST be identical on Render and Railway!
JWT_SECRET=super_secret_election_key_2026_xyz123

# ─── Server Port ────────────────────────────────────────────────────
PORT=3000

# ─── Parallel Deployment URLs (optional, for CORS) ──────────────────
# Set these so both deployments can cross-communicate (e.g. for the status page).
# RENDER_URL=https://your-app.onrender.com
# RAILWAY_URL=https://your-app.up.railway.app
