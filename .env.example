# 🗳️ Election Management System — Environment Variables

# ─── Database Mode ──────────────────────────────────────────────────
# Leave all DB_ variables commented out to use the Zero-Dependency Local JSON database (db.json).
# Uncomment them to connect to a MySQL database instead.

# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=your_mysql_password_here
# DB_NAME=election_db

# ─── Auth Secrets ───────────────────────────────────────────────────
# Secret key used for signing JWT tokens. Change this to a random string!
JWT_SECRET=super_secret_election_key_2026_xyz123

# ─── Server Port ────────────────────────────────────────────────────
PORT=3000
